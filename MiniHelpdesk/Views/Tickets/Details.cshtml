@model MiniHelpdesk.Models.Ticket

<h2>@Model.Title (@Model.Status)</h2>
<p>@Model.Description</p>

@if (Model.Status == "Open")
{
<form asp-action="Close" asp-route-id="@Model.Id" method="post">
    <button type="submit" class="btn btn-danger">Zamknij zgłoszenie</button>
</form>
}

<hr />
<h3>Komentarze</h3>
<ul>
    @foreach (var c in Model.Comments)
    {
    <li><strong>@c.Author:</strong> @c.Content <em>(@c.CreatedAt)</em></li>
    }
</ul>